\\l "_Appendix_A:_Interface" }{{\*\datafield 08d0c9ea79f9bace118c8200aa004ba90b0200000008000000170000005f0041007000700065006e006400690078005f0041003a005f0049006e007400650072006600610063006500000000}}}{\fldrslt {\cs26\ul\cf2 Appen
dix A: Interface Definition Files}}}{: }{\field\flddirty{\*\fldinst { HYPERLINK  \\l "_CORBA" }{{\*\datafield 08d0c9ea79f9bace118c8200aa004ba90b0200000008000000070000005f0043004f00520042004100000000}}}{\fldrslt {\cs26\ul\cf2 CORBA}}}{).
\par 
\par Each package is mapped to a CORBA module of the same name.
\par 
\par Two-dimensional arrays (e.g. matrices) are modeled with a sequence of sequences.  All 2D arrays in this specification should be regular, so each sub-sequence in the 2D array should have the same length.
\par 
\par {\*\bkmkstart _Toc467222154}{\*\bkmkstart _Toc496925561}{\listtext\pard\plain\s2 \b \hich\af0\dbch\af0\loch\f0 6.3\tab}}\pard\plain \s2\ql \fi-864\li864\ri0\sb120\sa120\keepn\widctlpar
\jclisttab\tx864\aspalpha\aspnum\faauto\ls3\ilvl1\outlinelevel1\adjustright\rin0\lin864\itap0 \b\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {Java profile{\*\bkmkend _Toc467222154}{\*\bkmkend _Toc496925561}
\par }\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {The Java profile is specified in the attached Java source files.
\par 
\par Each Java package is called \'93}{\f2 org.opengis.xx}{\'94 where \'93}{\f2 xx}{\'94 is the two-character package prefix in lower case.
\par 
\par The Java source includes tagged comments.  These comments were used to generate the accompanying HTML documentation using the JavaDoc utility.
\par 
\par In the Java profile, structures are modeled with Java classes (e.g. PT_CoordinatePoint), and interfaces are used for entities that will have many different implementations (e.g. CS_ProjectedCoordinateSystem).
\par 
\par This specification says that structures used as return values should use \'93return-by-value\'94
 semantics.  This means that whenever a Java method has an object return type, the implementation should create a new Java object.  Since this is not very efficient, there are also pass-by-reference versions of heavily used functions (e.g. double[] }{\b 
transformList}{(double[] ord)).
\par 
\par Matrices are modeled with the Java type \'93}{\f2 double[][]}{\'94.  Although the Java language allows ragged multi-dimensional arrays, all arrays in this specification should be regular (i.e. rectangular in 2D).
\par {\*\bkmkstart _Well_Known_Text_format}{\*\bkmkstart _Toc467222166}{\*\bkmkstart _Toc467222158}{\*\bkmkend _Well_Known_Text_format}{\listtext\pard\plain\s1 \b\fs28 \hich\af0\dbch\af0\loch\f0 7\tab}}\pard\plain 
\s1\ql \fi-720\li720\ri0\sb120\sa120\keepn\widctlpar\jclisttab\tx720\aspalpha\aspnum\faauto\ls3\outlinelevel0\adjustright\rin0\lin720\itap0 \b\fs28\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\page {\*\bkmkstart _Toc496925562}Well-Known Text format
{\*\bkmkend _Toc467222166}{\*\bkmkend _Toc496925562}
\par }\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\par Many entities in this specification can be printed in a well-known text format.  This allows objects to be stored in databases (persistence), and transmitted between interoperating computer programs.
\par 
\par Each entity has a keyword in upper case (for example, }{\f2\fs18 DATUM}{ or }{\f2\fs18 UNIT}{) followed by the defining, comma-delimited, parameters of the object in brackets. Some objects are composed of objects so the r
esult is a nested structure. Implementations are free to substitute standard brackets ( ) for square brackets [ ] and should be prepared to read both forms of brackets.
\par 
\par The definition for WKT is shown below using Extended Backus Naur Form (EBNF).  The WKT for a math transform can be used inside a fitted coordinate system, so it is shown first.
\par 
\par {\*\bkmkstart _Toc496925563}{\listtext\pard\plain\s2 \b \hich\af0\dbch\af0\loch\f0 7.1\tab}}\pard\plain \s2\ql \fi-864\li864\ri0\sb120\sa120\keepn\widctlpar\jclisttab\tx864\aspalpha\aspnum\faauto\ls3\ilvl1\outlinelevel1\adjustright\rin0\lin864\itap0 
\b\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {Math Transform WKT{\*\bkmkend _Toc496925563} 
\par }\pard\plain \s28\ql \fi-720\li720\ri-450\widctlpar\aspalpha\aspnum\faauto\adjustright\rin-450\lin720\itap0 \f2\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\par <math transform> = <param mt> | <concat mt> | <inv mt> | <passthrough mt>
\par }\pard\plain \ql \fi-720\li720\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin720\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f2 <param mt> = PARAM_MT["<classification name>" \{,<parameter>\}* ]
\par <parameter> = PARAMETER["<name>", <value>]
\par <value> = <number>
\par <concat mt> = CONCAT_MT[<math transform> \{,<math transform>\}* ]
\par <inv mt> = INVERSE_MT[<math transform>]
\par <passthrough mt> = PASSTHROUGH_MT[<integer>, <math transform>]
\par }\pard \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {
\par {\*\bkmkstart _Toc496925564}{\listtext\pard\plain\s2 \b \hich\af0\dbch\af0\loch\f0 7.2\tab}}\pard\plain \s2\ql \fi-864\li864\ri0\sb120\sa120\keepn\widctlpar\jclisttab\tx864\aspalpha\aspnum\faauto\ls3\ilvl1\outlinelevel1\adjustright\rin0\lin864\itap0 
\b\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {Coordinate System WKT{\*\bkmkend _Toc496925564} 
\par }\pard\plain \ql \li0\ri-450\widctlpar\aspalpha\aspnum\faauto\adjustright\rin-450\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\par }\pard\plain \s28\ql \fi-720\li720\ri-450\widctlpar\aspalpha\aspnum\faauto\adjustright\rin-450\lin720\itap0 \f2\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
<coordinate system> = <horz cs> | <geocentric cs> | <vert cs> | <compd cs> | <fitted cs> | <local cs>
\par }\pard\plain \ql \fi-720\li720\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin720\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f2 <horz cs> = <geographic cs> | <projected cs>
\par <projected cs> = PROJCS["<name>", <geographic cs>, <projection>, \{<parameter>,\}* <linear unit> \{,<twin axes>\}\{,<authority>\}]
\par <projection> = PROJECTION["<name>" \{,<authority>\}]
\par <geographic cs> = GEOGCS["<name>", <datum>, <prime meridian>, <angular unit> \{,<twin axes>\} \{,<authority>\}]
\par <datum> = DATUM["<name>", <spheroid> \{,<to wgs84>\} \{,<authority>\}]
\par <spheroid> = SPHEROID["<name>", <semi-major axis>, <inverse flattening> \{,<authority>\}]
\par <semi-major axis> = <number>
\par <inverse flattening> = <number>
\par <prime meridian> = PRIMEM["<name>", <longitude> \{,<authority>\}]
\par <longitude> = <number>
\par <angular unit> = <unit>
\par <linear unit> = <unit>
\par <unit> = UNIT["<name>", <conversion factor> \{,<authority>\}]
\par <conversion factor> = <number>
\par }\pard \ql \fi-720\li720\ri-1800\widctlpar\aspalpha\aspnum\faauto\adjustright\rin-1800\lin720\itap0 {\f2 <geocentric cs> = GEOCCS["<name>", <datum>, <prime meridian>, <linear unit> \{,<axis>, <axis>, <axis>\} \{,<authority>\}]
\par }\pard \ql \fi-720\li720\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin720\itap0 {\f2 <authority> = AUTHORITY["<name>", "<code>"]
\par <vert cs> = VERT_CS["<name>", <vert datum>, <linear unit>, \{<axis>,\} \{,<authority>\}]
\par <vert datum> = VERT_DATUM["<name>", <datum type> \{,<authority>\}]
\par <datum type> = <number>
\par <compd cs> = COMPD_CS["<name>", <head cs>, <tail cs> \{,<authority>\}]
\par <head cs> = <coordinate system>
\par <tail cs> = <coordinate system>
\par <twin axes> = <axis>, <axis>
\par <axis> = AXIS["<name>", NORTH | SOUTH | EAST | WEST | UP | DOWN | OTHER]
\par <to wgs84s> = TOWGS84[<seven param>]
\par <seven param> = <dx>,  <dy>, <dz>, <ex>, <ey>, <ez>, <ppm>
\par <dx> = <number>
\par <dy> = <number>
\par <dz> = <number>
\par <ex> = <number>
\par <ey> = <number>
\par <ez> = <number>
\par <ppm> = <number>
\par <fitted cs> = FITTED_CS["<name>", }{<to base>}{\f2 , <base cs>]
\par <to base> = <math transform>
\par <base cs> = <coordinate system>
\par <local cs> = LOCAL_CS["<name>", <local datum>, <unit>, <axis>, \{,<axis>\}* \{,<authority>\}]
\par <local datum> = LOCAL_DATUM["<name>", <datum type> \{,<authority>\}]
\par }\pard \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\b 
\par {\*\bkmkstart _Toc496925565}{\listtext\pard\plain\s2 \b \hich\af0\dbch\af0\loch\f0 7.3\tab}}\pard\plain \s2\ql \fi-864\li864\ri0\sb120\sa120\keepn\widctlpar\jclisttab\tx864\aspalpha\aspnum\faauto\ls3\ilvl1\outlinelevel1\adjustright\rin0\lin864\itap0 
